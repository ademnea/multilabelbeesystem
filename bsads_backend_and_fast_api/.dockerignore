# Use this for production builds
# Copy from .dockerignore.production or include relevant patterns

# Git
.git
.gitignore
.github

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/

# Environment files
.env
.env.*
!.env.example

# Documentation (except API.md)
*.md
!API.md

# Development files
docker-compose.yml
railway.toml
RAILWAY_MIGRATION_GUIDE.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
test_*.py

# Uploads (uses volume mount)
uploads/*

# Build artifacts
dist/
build/
*.egg-info/

# Misc
.DS_Store
Thumbs.db

# Deployment files (not needed in image)
test_deployment.sh
.dockerignore.production
