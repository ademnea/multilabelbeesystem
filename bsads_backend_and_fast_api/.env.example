# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://bee_user:bee_user@localhost:5432/bee_db

# ⚠️  DEVELOPMENT ONLY: Auto-reset database on startup (DELETES ALL DATA!)
# Set to true to automatically drop and recreate all tables with fresh schema
# This is useful during development when models change frequently
# NEVER use this in production!
RESET_DATABASE=false

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Change this to a long random string in production
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-in-production

# ── File Storage ──────────────────────────────────────────────────────────────
# Folder where manually uploaded audio files are saved (relative to project root)
UPLOAD_DIR=uploads

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Read token — get yours at https://huggingface.co/settings/tokens
# Required for private Spaces; optional for public ones.
HF_TOKEN=

# Write token — only needed for CI/CD model pushes, not required to run the API
HF_WRITE_TOKEN=

# Gradio Space that receives audio bytes and returns classification results
# Format: owner/space-name  (this is where inference actually runs)
HF_SPACE_NAME=DerrickLegacy256/bee-audio-classifier

# HuggingFace model repository (used by CI/CD training pipeline, not the API directly)
HF_MODEL_ID=DerrickLegacy256/bee_swarming_and_absconment

# ── Poller Timing ─────────────────────────────────────────────────────────────
# How often the discovery + inference background jobs run (seconds)
# Recommended: 60s for production (allows time for inference to complete)
POLL_INTERVAL_SECONDS=60

# Offset between discovery job and inference job so discovery always runs first
POLL_OFFSET_SECONDS=15

# How often to check for stuck 'processing' records and reset them (minutes)
RECOVERY_INTERVAL_MINUTES=3

# ── Inference Timeout ─────────────────────────────────────────────────────────
# Max seconds to wait for the HuggingFace Gradio Space to return a result
# Increase if you have slow WAN or large audio files
INFERENCE_TIMEOUT_SECONDS=240

# ── Weather API ───────────────────────────────────────────────────────────────
# Optional: OpenWeatherMap API key for weather data
# If not set, the system will use Open-Meteo API (free, no key required)
# Get your key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=
