# Farmer Audio Recording Server Configuration
# Copy this file to .env and update with your values

# Admin Key - Generate with: openssl rand -hex 32
# NEVER share this key! It's your master password.
ADMIN_KEY=128d3e857c80d23134206cbd707300050abc64966a1b5be9c107f8bd7d5b56eb

# Recordings Directory (inside container)
RECORDINGS_DIR=/home/farmer/recordings

# Hive Conditions Directory (inside container)
HIVE_CONDITIONS_DIR=/home/farmer/hive_conditions

# API Keys Database File (inside container)
KEYS_FILE=/data/api_keys.json

# Ngrok Authentication Token (get from https://dashboard.ngrok.com/get-started/your-authtoken)
# Optional but recommended for stable URLs and higher limits
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
